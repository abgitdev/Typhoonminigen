# Swift Package Manager / build artifacts
.build*/
.swiftpm/
Package.resolved.bak
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# macOS
.DS_Store

# Models & generated content are NOT stored in the repo.
# They live under ~/Library/Application Support/Typhoonminigen/ at runtime.
/Models/
/Images/
*.safetensors
*.png

# Defence in depth: user-data files only ever live under ~/Library at runtime, but block them
# by name too so a stray copy (e.g. dragged into the repo) can never be committed.
generations*.json
*.log
custom-presets*.json

# README screenshots ARE tracked (the *.png rule above is for generated images).
# ** so screenshots in any docs/ subfolder (docs/screenshots/…) are kept too.
!docs/**/*.png

# Editor
.vscode/
*.swp

# Built app bundles (regenerated by the build)
*.app

# Icon source assets in tools/ ARE tracked (the *.png rule above is for generated images)
!tools/*.png
*.profraw
